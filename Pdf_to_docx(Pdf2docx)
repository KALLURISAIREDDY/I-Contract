    print(f"""
  PDF    : {PDF_PATH}
  Output : {OUTPUT_DOCX}

  FIXES IN THIS VERSION
  ─────────────────────────────────────────────────────────────────────
  FIX 1  pdfplumber session kept alive during compression (page objects
         no longer go stale)

  FIX 2  available_pt = page_h - max(docx_margin, pdf_margin) on each
         side; guaranteed positive with a 5% fallback

  FIX 3  geo assigned to sections before params are derived

  FIX 4  fix_overflow wired correctly (pdf_path passed explicitly;
         pdf_footers argument removed since footer code is commented out)

  FIX 5  overflow only triggered when > {MIN_OVERFLOW_TRIGGER_PT}pt (suppresses FP noise)

  FIX 6  section reconciler splits content on page-break markers when
         pdf2docx produces fewer sections than PDF pages
""")

    if not os.path.exists(PDF_PATH):
        print(f"  ERROR: PDF not found: {PDF_PATH}")
        sys.exit(1)

    try:
        geos      = extract_pdf_layout(PDF_PATH)
        pdf_lines = extract_pdf_lines_per_page(PDF_PATH)

        input("\n  Press ENTER to convert PDF → DOCX ...")
        convert_pdf_to_docx(PDF_PATH, TEMP_DOCX)

        input("\n  Press ENTER to run fixes ...")
        fix_overflow(TEMP_DOCX, geos, OUTPUT_DOCX, pdf_lines, PDF_PATH)

