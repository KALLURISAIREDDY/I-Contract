@dataclass
class ParaState:
    p_elem:    object
    idx:       int   = 0
    text:      str   = ""
    in_table:  bool  = False
    font_hp:   int   = 20
    before_tw: int   = 0
    after_tw:  int   = 0
    line_val:  int   = 0
    line_rule: str   = ""
    params:    Optional[PageParams] = None

    @property
    def font_pt(self) -> float:
        return self.font_hp / HALF_PTS_PER_PT

    @property
    def has_explicit_line(self) -> bool:
        return self.line_val > 0

    @property
    def effective_line(self) -> int:
        return self.line_val if self.has_explicit_line else WORD_SINGLE_LINE

    @property
    def line_multiplier(self) -> float:
        return self.effective_line / WORD_SINGLE_LINE

    @property
    def line_height_pt(self) -> float:
        return self.line_multiplier * self.font_pt

    @property
    def floor_ratio(self) -> float:
        return self.params.floor_ratio if self.params else _TYPO_ABS_FLOOR_RATIO

    @property
    def floor_line(self) -> int:
        return max(1, int(self.effective_line * self.floor_ratio))

    @property
    def above_single_headroom(self) -> int:
        return max(0, self.effective_line - WORD_SINGLE_LINE)

    @property
    def line_headroom(self) -> int:
        return max(0, self.effective_line - self.floor_line)

    @property
    def para_spacing_pt(self) -> float:
        return (self.before_tw + self.after_tw) / TWIPS_PER_PT

    def to_dict(self) -> dict:
        return {
            "idx":            self.idx,
            "text":           self.text[:80],
            "in_table":       self.in_table,
            "font_pt":        round(self.font_pt, 1),
            "line_height_pt": round(self.line_height_pt, 2),
            "floor_ratio":    round(self.floor_ratio, 4),
            "floor_line":     self.floor_line,
            "before_pt":      round(self.before_tw / TWIPS_PER_PT, 2),
            "after_pt":       round(self.after_tw  / TWIPS_PER_PT, 2),
            "line_val":       self.line_val,
            "effective_l":    self.effective_line,
            "line_rule":      self.line_rule,
        }


