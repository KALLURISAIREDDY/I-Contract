        print(f"  {DIAG_JSON}  — geometry + overflow diagnostics")
        print(f"  {LOG_JSON}   — all compression actions by tier")
        print(f"  {OUTPUT_DOCX} — verify in Word:")
        print(f"    • Page count = {len(geos)} (should match PDF)")
        print(f"    • Text should remain within each page without merging\n")

    except Exception as exc:
        import traceback
        print(f"\n  ERROR  {type(exc).__name__}: {exc}")
        traceback.print_exc()
        sys.exit(1)


if __name__ == "__main__":
