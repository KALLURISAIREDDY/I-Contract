#  PDF LAYOUT EXTRACTION
# ═══════════════════════════════════════════════════════════════════════════════

def _measure_page_gaps(words: list) -> float:
    if len(words) < 2:
        return 0.0
    sw   = sorted(words, key=lambda w: (w["top"], w["x0"]))
    gaps = sorted([sw[i + 1]["top"] - sw[i]["bottom"]
                   for i in range(len(sw) - 1)
                   if sw[i + 1]["top"] - sw[i]["bottom"] > 0])
    return gaps[len(gaps) // 2] if gaps else 0.0


def _compute_buffer_dynamic(body_h, content_h, median_gap_pt):
    if content_h <= 0 or body_h <= 0:
        return 1.0, 1.0, 1.0
    raw_buf      = body_h / content_h
    leading_frac = max(0.01, median_gap_pt / content_h) if median_gap_pt > 0 else 0.01
    buf_floor    = 1.0 + leading_frac
    buf_ceil     = raw_buf
    if buf_floor >= buf_ceil:
        buf_floor = 1.0 + 0.01
    return max(buf_floor, min(buf_ceil, raw_buf)), buf_floor, buf_ceil


def _collect_page_font_sizes(page) -> int:
    sizes = sorted([int(round(ch["size"] * HALF_PTS_PER_PT))
                    for ch in (page.chars or []) if ch.get("size") and ch["size"] > 0])
    return sizes[len(sizes) // 2] if sizes else 20


def extract_pdf_layout(pdf_path: str) -> List[PageGeometry]:
    _hdr("STEP 1: PDF LAYOUT EXTRACTION")
    geos: List[PageGeometry] = []
    with pdfplumber.open(pdf_path) as pdf:
        n = len(pdf.pages)
        print(f"  Pages detected: {n}")
        for i, page in enumerate(pdf.pages, 1):
            ph    = float(page.height)
            pw    = float(page.width)
            words = page.extract_words() or []
            if words:
                ct, cb     = min(w["top"] for w in words), max(w["bottom"] for w in words)
                has_text   = True
                median_gap = _measure_page_gaps(words)
            else:
                ct, cb     = 0.0, ph
                has_text   = False
                median_gap = 0.0
            content_h = max(0.0, cb - ct)
            top_m     = ct
            bot_m     = ph - cb
            body_h    = ph - top_m - bot_m
            buf, buf_fl, buf_cl = (
                _compute_buffer_dynamic(body_h, content_h, median_gap)
                if has_text and content_h > 0 else (1.0, 1.0, 1.0)
            )
            geos.append(PageGeometry(
                page_num       = i,
                page_h_pt      = ph,
                page_w_pt      = pw,
                content_top    = ct,
                content_bot    = cb,
                content_h_pt   = content_h,
                top_margin     = top_m,
                bot_margin     = bot_m,
                body_h_pt      = body_h,
                buf_floor      = buf_fl,
                buf_ceil       = buf_cl,
                buffer         = buf,
                has_text       = has_text,
                median_gap_pt  = median_gap,
                median_font_hp = _collect_page_font_sizes(page),
            ))
            print(f"  Page {i:>3}/{n}  h={ph:.1f}  buf=×{buf:.4f}", end="\r", flush=True)
    print()
    _print_geo_table(geos)
    return geos


def _print_geo_table(geos: List[PageGeometry]) -> None:
    print(f"\n  {'Pg':>3}  {'PageH':>7}  {'Body':>7}  {'Content':>8}  "
          f"{'Buf':>7}  {'EffH':>8}  {'Text'}")
    print("  " + "─" * 60)
    for g in geos:
        print(f"  {g.page_num:>3}  {g.page_h_pt:>7.2f}  {g.body_h_pt:>7.2f}  "
              f"{g.content_h_pt:>8.2f}  ×{g.buffer:>6.4f}  {g.effective_h:>8.2f}  "
              f"{'yes' if g.has_text else 'img'}")


