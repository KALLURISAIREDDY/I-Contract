#  SECTION PARSING  — FIX 2: corrected available_pt calculation
# ═══════════════════════════════════════════════════════════════════════════════

def _available_from_sectpr(sp, geo: Optional[PageGeometry]):
    """
    Compute usable body height for a section.

    FIX: Previously this mixed DOCX margin values and PDF margin values in
    an inconsistent way that could produce negative or zero available_pt.
    Now:
      - Use page height from geo (actual PDF page size) when available,
        falling back to the w:pgSz value.
      - Take the LARGER of the DOCX and PDF margin on each side, so we
        never underestimate margins.
      - Guarantee available_pt > 0 with a 5% floor.
    """
    # Determine page height
    if geo is not None:
        ph = geo.page_h_pt
    elif sp is not None:
        pg_sz = sp.find(qn("w:pgSz"))
        ph    = _attr_dxa_to_pt(pg_sz.get(qn("w:h"))) if pg_sz is not None else 792.0
        if ph <= 0:
            ph = 792.0
    else:
        ph = 792.0

    # Read DOCX margin values
    tm_docx = bm_docx = 0.0
    if sp is not None:
        pg_mar = sp.find(qn("w:pgMar"))
        if pg_mar is not None:
            top_raw = _attr_dxa_to_pt(pg_mar.get(qn("w:top")))
            bot_raw = _attr_dxa_to_pt(pg_mar.get(qn("w:bottom")))
            hdr_raw = _attr_dxa_to_pt(pg_mar.get(qn("w:header")))
            ftr_raw = _attr_dxa_to_pt(pg_mar.get(qn("w:footer")))
            # Effective DOCX margin = whichever is larger: margin or header/footer distance
            tm_docx = max(top_raw, hdr_raw) if hdr_raw > 0 else top_raw
            bm_docx = max(bot_raw, ftr_raw) if ftr_raw > 0 else bot_raw

    # Read PDF margin values
    top_pdf = geo.top_margin if geo else 0.0
    bot_pdf = geo.bot_margin if geo else 0.0

    # Take the larger margin on each side to avoid underestimating
    top = max(tm_docx, top_pdf)
    bot = max(bm_docx, bot_pdf)

    # Safety: if margins are zero (e.g., image-only page), use PDF margins
    if top == 0.0:
        top = top_pdf if top_pdf > 0 else ph * 0.08
    if bot == 0.0:
        bot = bot_pdf if bot_pdf > 0 else ph * 0.08

    available = ph - top - bot

    # Hard fallback: always leave at least 5% of page height as available
    if available <= 0:
        fallback_margin = ph * 0.08
        top       = fallback_margin
        bot       = fallback_margin
        available = ph - top - bot

    return available, ph, top, bot


def parse_sections(doc: Document, geos: List[PageGeometry]) -> List[Section]:
    body = doc.element.body
    raw: List[Section] = []
    cur = Section(index=1)
    for elem in body:
        tag = _ltag(elem)
        if tag == "sectPr":
            geo = geos[len(raw)] if len(raw) < len(geos) else None
            av, ph, tm, bm = _available_from_sectpr(elem, geo)
            cur.sect_pr, cur.available_pt = elem, av
            cur.page_h_pt, cur.top_margin_pt, cur.bot_margin_pt = ph, tm, bm
            raw.append(cur)
            cur = Section(index=len(raw) + 1)
        elif tag == "p":
            pPr    = elem.find(qn("w:pPr"))
            sectPr = pPr.find(qn("w:sectPr")) if pPr is not None else None
            cur.body_elems.append(elem)
            if sectPr is not None:
                geo = geos[len(raw)] if len(raw) < len(geos) else None
                av, ph, tm, bm = _available_from_sectpr(sectPr, geo)
                cur.sect_pr, cur.available_pt = sectPr, av
                cur.page_h_pt, cur.top_margin_pt, cur.bot_margin_pt = ph, tm, bm
                raw.append(cur)
                cur = Section(index=len(raw) + 1)
        else:
            cur.body_elems.append(elem)

    # Collect any trailing section
    if cur not in raw and (cur.body_elems or cur.sect_pr):
        if cur.sect_pr is None and raw:
            cur.sect_pr = raw[-1].sect_pr
        geo = geos[len(raw)] if len(raw) < len(geos) else (geos[-1] if geos else None)
        av, ph, tm, bm = _available_from_sectpr(cur.sect_pr, geo)
        cur.available_pt = av
        cur.page_h_pt, cur.top_margin_pt, cur.bot_margin_pt = ph, tm, bm
        raw.append(cur)

    sections = _reconcile(raw, len(geos))

    # FIX 3: assign geo BEFORE params; params derivation depends on geo
    for i, sec in enumerate(sections):
        sec.geo = geos[i] if i < len(geos) else (geos[-1] if geos else None)

    return sections


def _reconcile(raw: List[Section], expected: int) -> List[Section]:
    """
    FIX 6: Robust reconciliation when section count != PDF page count.

    pdf2docx often produces a single section for a multi-page document
    (because Word's section model is not per-page).  In that case we
    replicate the single section for each PDF page so every page gets
    its own geo and params.
    """
    if len(raw) == expected:
        for i, s in enumerate(raw, 1):
            s.index = i
        return raw

    if len(raw) > expected:
        # Merge extra sections into the last expected slot
        target = raw[expected - 1]
        for extra in raw[expected:]:
            target.body_elems.extend(extra.body_elems)
            if extra.sect_pr is not None:
                target.sect_pr = extra.sect_pr
        merged = raw[:expected]
        for i, s in enumerate(merged, 1):
            s.index = i
        print(f"  [reconcile] merged {len(raw)-expected} extra → {expected} total")
        return merged

    # Fewer sections than pages (most common with pdf2docx)
    print(f"  [reconcile] {len(raw)} DOCX sections for {expected} PDF pages "
          f"— splitting content across pages")

    # Distribute paragraphs evenly across expected pages
    # (A simple even split; page-break markers are honoured below)
    if not raw:
        # Degenerate: no sections at all
        fallback = [Section(index=i+1) for i in range(expected)]
        return fallback

    # Collect all body elements from all raw sections
    all_elems = []
    for s in raw:
        all_elems.extend(s.body_elems)
    ref_sectpr = raw[-1].sect_pr  # reuse last sectPr for all pages

    # Find explicit page-break positions
    page_break_idxs = []
    for k, elem in enumerate(all_elems):
        tag = _ltag(elem)
        if tag == "p":
            for br in elem.findall(".//" + qn("w:br")):
                if br.get(qn("w:type")) in ("page", "column"):
                    page_break_idxs.append(k)
                    break

    # Build sections by splitting on page breaks first
    sections: List[Section] = []
    cur = Section(index=1, sect_pr=ref_sectpr)
    for k, elem in enumerate(all_elems):
        cur.body_elems.append(elem)
        if k in page_break_idxs:
            sections.append(cur)
            cur = Section(index=len(sections)+1, sect_pr=ref_sectpr)
    if cur.body_elems or not sections:
        sections.append(cur)

    # If we still have fewer sections than expected, split largest sections
    while len(sections) < expected:
        largest_i = max(range(len(sections)),
                        key=lambda i: len(sections[i].body_elems))
        s = sections[largest_i]
        if len(s.body_elems) < 2:
            break  # Cannot split further
        mid = len(s.body_elems) // 2
        s1 = Section(index=0, sect_pr=ref_sectpr, body_elems=s.body_elems[:mid])
        s2 = Section(index=0, sect_pr=ref_sectpr, body_elems=s.body_elems[mid:])
        sections = sections[:largest_i] + [s1, s2] + sections[largest_i+1:]

    # Trim to expected count if we ended up with too many
    if len(sections) > expected:
        for extra in sections[expected:]:
            sections[expected-1].body_elems.extend(extra.body_elems)
        sections = sections[:expected]

    for i, s in enumerate(sections, 1):
        s.index = i
    return sections


# ═══════════════════════════════════════════════════════════════════════════════
#  TIER 0: MATERIALIZE IMPLICIT LINE SPACING
# ═══════════════════════════════════════════════════════════════════════════════

def materialize_line_spacing(sec: Section, log: List[Action],
                             doc: Document) -> None:
    count = 0
    for p, tbl in sec.iter_paragraphs():
        ps = _read_para(p, 0, tbl, sec.params)
        if not ps.has_explicit_line:
            style_line = _get_style_line_val(p, doc)
            floor_v    = max(1, int(style_line * sec.params.floor_ratio))
            _write_spacing(p, ps.before_tw, ps.after_tw,
                           line_val=style_line, floor_val=floor_v)
            log.append(Action(sec.index, ps.idx, ps.text,
                               "0_materialize", "w:line", 0.0, float(style_line), 0.0))
            count += 1
    if count:
        print(f"    Tier 0: materialized {count} implicit line spacings")


# ═══════════════════════════════════════════════════════════════════════════════
#  TIER 1: PARAGRAPH SPACING — GREEDY, LARGEST-FIRST
# ═══════════════════════════════════════════════════════════════════════════════

def tier1_drain_para_spacing(sec: Section, log: List[Action]) -> float:
    need_pt = sec.overflow_pt
    if need_pt <= sec.resolved_pt:
        return 0.0

    states = sorted(
        [s for s in sec.live_states() if s.para_spacing_pt > 0],
        key=lambda s: s.para_spacing_pt,
        reverse=True,
    )
    if not states:
        return need_pt

    total_removed = 0.0
    touched       = 0

    for ps in states:
        if need_pt <= sec.resolved_pt:
            break

        available_pt = ps.para_spacing_pt
        remove_pt    = min(available_pt, need_pt)
        remove_frac  = remove_pt / available_pt if available_pt > 0 else 0.0

        new_b = max(0, int(ps.before_tw * (1.0 - remove_frac)))
        new_a = max(0, int(ps.after_tw  * (1.0 - remove_frac)))

        removed_pt = (ps.before_tw + ps.after_tw - new_b - new_a) / TWIPS_PER_PT
        if removed_pt <= 0:
            continue

        _write_spacing(ps.p_elem, new_b, new_a)
        for fname, old_tw, new_tw in [("before", ps.before_tw, new_b),
                                       ("after",  ps.after_tw,  new_a)]:
            if old_tw != new_tw:
                log.append(Action(sec.index, ps.idx, ps.text,
                                   "1_para_spacing", fname,
                                   old_tw / TWIPS_PER_PT, new_tw / TWIPS_PER_PT,
                                   (old_tw - new_tw) / TWIPS_PER_PT))
        total_removed += removed_pt
        need_pt        = max(0.0, need_pt - removed_pt)
        touched       += 1

    remaining = sec.overflow_pt
    _tlog(1, f"para spacing greedy ({touched} paras touched)",
          total_removed, remaining)
    return remaining


# ═══════════════════════════════════════════════════════════════════════════════
#  TIER 2: ABOVE-SINGLE LINE SPACING — GREEDY, MOST-SPACED-FIRST
# ═══════════════════════════════════════════════════════════════════════════════

def tier2_compress_above_single(sec: Section, log: List[Action]) -> float:
    need_pt = sec.overflow_pt
    if need_pt <= sec.resolved_pt:
        return 0.0

    states = sorted(
        [s for s in sec.live_states() if s.above_single_headroom > 0],
        key=lambda s: (s.above_single_headroom / WORD_SINGLE_LINE) * s.font_pt,
        reverse=True,
    )
    if not states:
        return need_pt

    total_removed = 0.0
    touched       = 0

    for ps in states:
        if need_pt <= sec.resolved_pt:
            break

        cur_l           = ps.effective_line
        headroom_pt     = (ps.above_single_headroom / WORD_SINGLE_LINE) * ps.font_pt
        remove_pt       = min(headroom_pt, need_pt)
        remove_frac     = remove_pt / headroom_pt if headroom_pt > 0 else 0.0
        remove_units    = max(1, int(ps.above_single_headroom * remove_frac))
        new_l           = max(WORD_SINGLE_LINE, cur_l - remove_units)
        actual_removed  = ((cur_l - new_l) / WORD_SINGLE_LINE) * ps.font_pt

        if actual_removed <= 0:
            continue

        _write_spacing(ps.p_elem, ps.before_tw, ps.after_tw,
                       line_val=new_l, floor_val=WORD_SINGLE_LINE)
        log.append(Action(sec.index, ps.idx, ps.text,
                           "2_above_single", "w:line",
                           float(cur_l), float(new_l), actual_removed))
        total_removed += actual_removed
        need_pt        = max(0.0, need_pt - actual_removed)
        touched       += 1

    remaining = sec.overflow_pt
    _tlog(2, f"above-single greedy ({touched} paras touched)",
          total_removed, remaining)
    return remaining


# ═══════════════════════════════════════════════════════════════════════════════
#  TIER 3: BELOW-SINGLE LINE COMPRESSION — GREEDY, MOST-HEADROOM-FIRST
# ═══════════════════════════════════════════════════════════════════════════════

def tier3_minimum_line_compression(sec: Section, log: List[Action]) -> float:
    need_pt = sec.overflow_pt
    if need_pt <= sec.resolved_pt:
        return 0.0

    states = sorted(
        [s for s in sec.live_states() if s.line_headroom > 0],
        key=lambda s: (s.line_headroom / WORD_SINGLE_LINE) * s.font_pt,
        reverse=True,
    )
    if not states:
        print(f"    Tier 3: all lines at floor — {need_pt:.3f}pt unresolvable here")
        return need_pt

    total_removed = 0.0
    touched       = 0

    for ps in states:
        if need_pt <= sec.resolved_pt:
            break

        cur_l       = ps.effective_line
        floor_v     = ps.floor_line
        headroom_pt = (ps.line_headroom / WORD_SINGLE_LINE) * ps.font_pt
        remove_pt   = min(headroom_pt, need_pt)
        remove_frac = remove_pt / headroom_pt if headroom_pt > 0 else 0.0
        remove_u    = max(1, int(ps.line_headroom * remove_frac))
        new_l       = max(floor_v, cur_l - remove_u)
        actual_rem  = ((cur_l - new_l) / WORD_SINGLE_LINE) * ps.font_pt

        if actual_rem <= 0:
            continue

        _write_spacing(ps.p_elem, ps.before_tw, ps.after_tw,
                       line_val=new_l, floor_val=floor_v)
        log.append(Action(sec.index, ps.idx, ps.text,
                           "3_line_compress", "w:line",
                           float(cur_l), float(new_l), actual_rem))
        total_removed += actual_rem
        need_pt        = max(0.0, need_pt - actual_rem)
        touched       += 1

    remaining = sec.overflow_pt
    _tlog(3, f"min line compress greedy ({touched} paras touched)",
          total_removed, remaining)
    return remaining


# ═══════════════════════════════════════════════════════════════════════════════
#  TIER R: RESIDUAL DRAIN  (≤2pt remaining)
# ═══════════════════════════════════════════════════════════════════════════════

def residual_drain(sec: Section, log: List[Action]) -> None:
    max_iters = int(sec.overflow_pt * TWIPS_PER_PT) + 10
    for _ in range(max_iters):
        if sec.overflow_pt <= sec.resolved_pt:
            break
        states  = sorted(sec.live_states(), key=lambda s: s.para_spacing_pt, reverse=True)
        changed = False
        for ps in states:
            if ps.after_tw > 0:
                _write_spacing(ps.p_elem, ps.before_tw, ps.after_tw - 1)
                log.append(Action(sec.index, ps.idx, ps.text,
                                   "R_residual", "after",
                                   ps.after_tw / TWIPS_PER_PT,
                                   (ps.after_tw - 1) / TWIPS_PER_PT,
                                   1.0 / TWIPS_PER_PT))
                changed = True
                break
            elif ps.before_tw > 0:
                _write_spacing(ps.p_elem, ps.before_tw - 1, ps.after_tw)
                log.append(Action(sec.index, ps.idx, ps.text,
                                   "R_residual", "before",
                                   ps.before_tw / TWIPS_PER_PT,
                                   (ps.before_tw - 1) / TWIPS_PER_PT,
                                   1.0 / TWIPS_PER_PT))
                changed = True
                break
        if not changed:
            break


# ═══════════════════════════════════════════════════════════════════════════════
#  TIER 4: PHYSICAL OVERFLOW SCALE  (last resort)
# ═══════════════════════════════════════════════════════════════════════════════

def tier4_physical_overflow(sec: Section, log: List[Action]) -> float:
    need_pt = sec.overflow_pt
    if need_pt <= sec.resolved_pt:
        return 0.0
    eff_h  = sec.effective_pdf_h
    avail  = sec.available_pt
    if eff_h <= 0:
        return need_pt
    scale  = min(1.0, avail / eff_h)
    if scale >= 1.0:
        return need_pt

    print(f"    Tier 4 (physical scale ×{scale:.4f}) — tiers 1–3 insufficient")
    total_removed = 0.0
    for ps in sec.live_states():
        new_b  = max(0, int(ps.before_tw * scale))
        new_a  = max(0, int(ps.after_tw  * scale))
        cur_l  = ps.effective_line
        new_l  = max(ps.floor_line, int(cur_l * scale))
        sp_rem = (ps.before_tw + ps.after_tw - new_b - new_a) / TWIPS_PER_PT
        ln_rem = ((cur_l - new_l) / WORD_SINGLE_LINE) * ps.font_pt
        _write_spacing(ps.p_elem, new_b, new_a, line_val=new_l, floor_val=ps.floor_line)
        for fname, ov, nv, rpt in [
            ("before", ps.before_tw/TWIPS_PER_PT, new_b/TWIPS_PER_PT, (ps.before_tw-new_b)/TWIPS_PER_PT),
            ("after",  ps.after_tw/TWIPS_PER_PT,  new_a/TWIPS_PER_PT, (ps.after_tw-new_a)/TWIPS_PER_PT),
            ("w:line", float(cur_l), float(new_l), ln_rem),
        ]:
            if abs(ov - nv) > 0.001:
                log.append(Action(sec.index, ps.idx, ps.text,
                                   "4_physical_scale", fname, ov, nv, rpt))
        total_removed += sp_rem + ln_rem
    remaining = max(0.0, need_pt - total_removed)
    _tlog(4, f"physical scale ×{scale:.4f}", total_removed, remaining)
    return remaining


# ═══════════════════════════════════════════════════════════════════════════════
#  TIER 5: REDISTRIBUTE SLACK
# ═══════════════════════════════════════════════════════════════════════════════

def tier5_redistribute_slack(sec: Section, pre_snap: Dict[int, ParaSnapshot],
                              log: List[Action]) -> None:
    if not pre_snap or not sec.params:
        return
    current_h = sec.current_content_height_pt()
    slack_pt  = sec.available_pt - current_h
    if slack_pt <= 0:
        return
    effective_safety = sec.params.expand_safety_pt * sec.params.safety_scale_factor
    if slack_pt <= effective_safety:
        return

    budget_pt        = slack_pt - effective_safety
    remaining_budget = budget_pt
    print(f"    Tier 5 (restore slack): slack={slack_pt:.2f}pt  "
          f"safety={effective_safety:.2f}pt  budget={budget_pt:.2f}pt")

    # Phase A: restore paragraph spacing
    phase_a               = 0.0
    sp_candidates         = []
    total_sp_deficit_pt   = 0.0
    for ps in sec.live_states():
        snap = pre_snap.get(ps.idx)
        if snap is None:
            continue
        d_tw = (snap.before_tw - ps.before_tw) + (snap.after_tw - ps.after_tw)
        if d_tw > 0:
            dp = d_tw / TWIPS_PER_PT
            sp_candidates.append((ps, snap,
                                   snap.before_tw - ps.before_tw,
                                   snap.after_tw  - ps.after_tw, dp))
            total_sp_deficit_pt += dp

    if total_sp_deficit_pt > 0 and remaining_budget > 0:
        frac = min(1.0, remaining_budget / total_sp_deficit_pt)
        for ps, snap, b_def, a_def, dp in sp_candidates:
            if remaining_budget <= 0:
                break
            pl = _read_para(ps.p_elem, ps.idx, ps.in_table, sec.params)
            new_b = min(snap.before_tw, pl.before_tw + int(b_def * frac))
            new_a = min(snap.after_tw,  pl.after_tw  + int(a_def * frac))
            rpt   = ((new_b - pl.before_tw) + (new_a - pl.after_tw)) / TWIPS_PER_PT
            if rpt <= 0:
                continue
            _write_spacing(pl.p_elem, new_b, new_a,
                           line_val=pl.line_val if pl.has_explicit_line else None)
            for fname, old_tw, nw in [("before", pl.before_tw, new_b),
                                       ("after",  pl.after_tw,  new_a)]:
                if old_tw != nw:
                    log.append(Action(sec.index, pl.idx, pl.text,
                                       "5_restore_spacing", fname,
                                       old_tw / TWIPS_PER_PT, nw / TWIPS_PER_PT,
                                       -(nw - old_tw) / TWIPS_PER_PT))
            remaining_budget -= rpt
            phase_a          += rpt

    # Phase B: restore line spacing
    phase_b             = 0.0
    total_ln_deficit_pt = 0.0
    ln_candidates       = []
    for ps in sec.live_states():
        snap   = pre_snap.get(ps.idx)
        if snap is None:
            continue
        snap_l = snap.line_val if snap.line_val > 0 else WORD_SINGLE_LINE
        if ps.effective_line < snap_l:
            du  = snap_l - ps.effective_line
            dp  = (du / WORD_SINGLE_LINE) * ps.font_pt
            ln_candidates.append((ps, snap_l, du, dp))
            total_ln_deficit_pt += dp

    if total_ln_deficit_pt > 0 and remaining_budget > effective_safety:
        frac = min(1.0, remaining_budget / total_ln_deficit_pt)
        for ps, snap_l, du, dp in ln_candidates:
            if remaining_budget <= 0:
                break
            pl  = _read_para(ps.p_elem, ps.idx, ps.in_table, sec.params)
            ru  = max(0, int(du * frac))
            if ru == 0:
                continue
            new_l = min(snap_l, pl.effective_line + ru)
            rpt   = ((new_l - pl.effective_line) / WORD_SINGLE_LINE) * pl.font_pt
            if rpt <= 0:
                continue
            _write_spacing(pl.p_elem, pl.before_tw, pl.after_tw,
                           line_val=new_l, floor_val=pl.floor_line)
            log.append(Action(sec.index, pl.idx, pl.text,
                               "5_restore_line", "w:line",
                               float(pl.effective_line), float(new_l), -rpt))
            remaining_budget -= rpt
            phase_b          += rpt

    total_r = phase_a + phase_b
    if total_r > 0:
        print(f"    Tier 5 restored: +{total_r:.2f}pt  "
              f"safety retained: {remaining_budget:.2f}pt")


# ═══════════════════════════════════════════════════════════════════════════════
#  PER-PAGE COMPRESS ORCHESTRATOR
# ═══════════════════════════════════════════════════════════════════════════════

def compress_page(sec: Section, log: List[Action], doc: Document,
                  page_object=None) -> None:
    """
    Orchestrate all compression tiers for a single overflowing page.

    FIX 1: page_object must still be a live pdfplumber Page (caller holds
    the session open).  This function no longer opens pdfplumber itself.
    """
    if not sec.is_overflow:
        return

    # FIX 3: params derived AFTER geo is assigned (done in parse_sections)
    sec.params = _derive_page_params(sec.geo, sec, page_object)
    overflow   = sec.overflow_pt

    t1 = sec.tier1_capacity_pt()
    t2 = sec.tier2_capacity_pt()
    t3 = sec.tier3_capacity_pt()
    buf_str = f"×{sec.geo.buffer:.4f}" if sec.geo else "N/A"

    print(f"\n  ── Page {sec.index}  "
          f"overflow={overflow:.3f}pt  avail={sec.available_pt:.2f}pt  "
          f"eff_h={sec.effective_pdf_h:.2f}pt  buf={buf_str}")
    print(f"     Capacity  T1(para_sp)={t1:.2f}pt  "
          f"T2(above_single)={t2:.2f}pt  T3(to_floor)={t3:.2f}pt  "
          f"total={t1+t2+t3:.2f}pt")
    print(f"     Floor ratio: {sec.params.floor_ratio:.4f}")

    if t1 + t2 + t3 < overflow:
        print(f"     ⚠ Max compressible ({t1+t2+t3:.2f}pt) < overflow ({overflow:.2f}pt)"
              f" → tier 4 will be needed")

    pre_snap = sec.snapshot_all()

    materialize_line_spacing(sec, log, doc)

    if sec.is_overflow:
        tier1_drain_para_spacing(sec, log)

    if sec.is_overflow:
        tier2_compress_above_single(sec, log)

    if sec.is_overflow:
        tier3_minimum_line_compression(sec, log)

    if 0 < sec.overflow_pt <= 2.0:
        residual_drain(sec, log)

    if sec.is_overflow:
        tier4_physical_overflow(sec, log)

    if not sec.is_overflow:
        print(f"     ✓ RESOLVED  (remaining: {sec.overflow_pt:.4f}pt)")
        tier5_redistribute_slack(sec, pre_snap, log)
    else:
        print(f"     ✗ STILL OVER by {sec.overflow_pt:.3f}pt — "
              f"content is physically too large for page")


# ═══════════════════════════════════════════════════════════════════════════════
#  MAIN ORCHESTRATOR  — FIX 1 & FIX 4
# ═══════════════════════════════════════════════════════════════════════════════

def fix_overflow(
    temp_docx:   str,
    geos:        List[PageGeometry],
    output_docx: str,
    pdf_lines:   Dict[int, List[PdfLine]],
    pdf_path:    str,            # FIX 4: pass PDF path explicitly
) -> None:
    _hdr("STEP 3: INLINE FIX + PAGE-LEVEL OVERFLOW CORRECTION  (v15-fixed)")

    doc      = Document(temp_docx)
    sections = parse_sections(doc, geos)

    print(f"\n  PDF pages     : {len(geos)}")
    print(f"  DOCX sections : {len(sections)}")

    _save_diag(sections, geos)
    _print_section_table(sections, "INITIAL STATE")

    log: List[Action] = []

    # Step A: Fix inline line-level overflow
    inline_fixed = fix_inline_line_overflow(sections, pdf_lines, log)
    if inline_fixed > 0:
        _print_section_table(sections, "AFTER INLINE FIX")

    # Step B: Per-page overflow compression
    overflow_secs = [s for s in sections if s.is_overflow]
    ok_secs       = [s for s in sections if not s.is_overflow]

    if overflow_secs:
        print(f"\n  Overflowing pages    : {[s.index for s in overflow_secs]}")
        print(f"  OK pages (untouched) : {[s.index for s in ok_secs]}")

        # FIX 1: open ONE pdfplumber session and keep it alive for the
        # entire compression pass so page objects remain valid.
        try:
            with pdfplumber.open(pdf_path) as pdf_handle:
                page_objects: Dict[int, object] = {
                    idx: pg for idx, pg in enumerate(pdf_handle.pages, 1)
                }
                for sec in overflow_secs:
                    compress_page(sec, log, doc, page_objects.get(sec.index))
        except Exception as exc:
            print(f"  [warn] pdfplumber session failed ({exc}); "
                  f"retrying without page objects (floor = typographic default)")
            for sec in overflow_secs:
                compress_page(sec, log, doc, page_object=None)

        _print_section_table(sections, "FINAL STATE")
        still = [s for s in sections if s.is_overflow]
        if still:
            print(f"\n  ⚠ Still overflowing: {[s.index for s in still]}")
        else:
            print(f"\n  ✓ All overflow resolved.")
    else:
        print("\n  No page overflow detected after inline fix.")

    print(f"\n  ✓ Inline lines fixed : {inline_fixed}")

    _save_log(log, sections)
    doc.save(output_docx)
    _cleanup(temp_docx)
    print(f"\n  Output → {output_docx}")


# ═══════════════════════════════════════════════════════════════════════════════
#  DISPLAY & LOGGING
# ═══════════════════════════════════════════════════════════════════════════════

def _hdr(title: str) -> None:
    print(f"\n{'═'*72}\n  {title}\n{'═'*72}")


def _tlog(tier, name, removed, residual):
    print(f"    Tier {tier} ({name:<50s}) "
          f"removed={removed:.3f}pt  remaining={residual:.3f}pt")


def _print_section_table(sections: List[Section], title: str) -> None:
    print(f"\n  {title}")
    print(f"  {'Pg':>3}  {'EffH':>8}  {'Avail':>8}  {'Over':>8}  "
          f"{'T1':>6}  {'T2':>6}  {'T3':>6}  Status")
    print("  " + "─" * 74)
    for sec in sections:
        ov  = sec.overflow_pt
        t1  = sec.tier1_capacity_pt()
        t2  = sec.tier2_capacity_pt()
        t3  = sec.tier3_capacity_pt()
        st  = f"OVER +{ov:.2f}pt" if ov > MIN_OVERFLOW_TRIGGER_PT else "OK"
        print(f"  {sec.index:>3}  {sec.effective_pdf_h:>8.2f}  "
              f"{sec.available_pt:>8.2f}  {ov:>8.3f}  "
              f"{t1:>6.2f}  {t2:>6.2f}  {t3:>6.2f}  {st}")


def _save_diag(sections, geos):
    geo_map = {g.page_num: g for g in geos}
    out = []
    for sec in sections:
        pg = geo_map.get(sec.index)
        out.append({
            "section":       sec.index,
            "docx_geometry": {
                "page_h_pt":    round(sec.page_h_pt,    2),
                "available_pt": round(sec.available_pt,  2),
                "col_width_pt": round(sec.available_width_pt(), 2),
            },
            "pdf_geometry":  pg.to_dict() if pg else {},
            "overflow_pt":   round(sec.overflow_pt, 3),
            "is_overflow":   sec.is_overflow,
            "paragraphs":    [s.to_dict() for s in sec.live_states()],
        })
    with open(DIAG_JSON, "w", encoding="utf-8") as f:
        json.dump({"tool": "pdf_to_docx_v15_fixed",
                   "sections": out}, f, indent=2, ensure_ascii=False)
    print(f"\n  Diagnostic → {DIAG_JSON}")


def _save_log(log: List[Action], sections: List[Section]) -> None:
    by_sec: Dict[int, List[Action]] = {}
    for a in log:
        by_sec.setdefault(a.section, []).append(a)
    sec_map = {s.index: s for s in sections}
    out = []
    for idx in sorted(by_sec):
        acts = by_sec[idx]
        sec  = sec_map.get(idx)
        out.append({
            "section":           idx,
            "available_pt":      round(sec.available_pt, 2) if sec else None,
            "final_overflow_pt": round(sec.overflow_pt,  3) if sec else None,
            "net_delta_pt":      round(sum(a.delta_pt for a in acts), 3),
            "action_count":      len(acts),
            "by_tier":           {
                t: round(sum(a.delta_pt for a in acts if a.tier == t), 3)
                for t in sorted({a.tier for a in acts})
            },
            "actions": [a.to_dict() for a in acts],
        })
    data = {"tool": "pdf_to_docx_v15_fixed",
            "total_actions": len(log),
            "sections_touched": len(out),
            "sections": out}
    with open(LOG_JSON, "w", encoding="utf-8") as f:
        json.dump(data, f, indent=2, ensure_ascii=False)
    print(f"  Log → {LOG_JSON}")


def _cleanup(path: str) -> None:
    if os.path.exists(path):
        os.remove(path)
        print(f"  Removed temp: {path}")


