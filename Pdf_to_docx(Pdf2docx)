# ═══════════════════════════════════════════════════════════════════════════════
#  DYNAMIC FLOOR RATIO DERIVATION
# ═══════════════════════════════════════════════════════════════════════════════

def _derive_floor_ratio_dynamic(
    page,
    median_font_pt: float,
    line_count:     int,
    available_pt:   float,
) -> float:
    """
    Compute the minimum safe line-spacing floor for this page.
    Returns value in [0.80, 0.95].

    If page is None (e.g. pdfplumber context already closed), falls back
    to the universal typographic floor (0.80).
    """
    descender_frac = _TYPO_DESCENDER_FRAC
    if page is not None:
        try:
            ratios = [
                ch["height"] / ch["size"]
                for ch in (page.chars or [])
                if ch.get("height") and ch.get("size") and ch["size"] > 0
                and 0.5 <= ch["height"] / ch["size"] <= 1.5
            ]
            if len(ratios) >= 10:
                med_ratio      = statistics.median(ratios)
                descender_frac = max(0.12, min(0.30, med_ratio - 0.70))
        except Exception:
            pass

    floor_from_font = 1.0 - descender_frac

    density_adj = 0.0
    if available_pt > 0 and median_font_pt > 0:
        natural_lines = available_pt / median_font_pt
        density       = line_count / natural_lines if natural_lines > 0 else 0.5
        density_adj   = max(0.0, min(0.10, (density - 0.5) * 0.10))

    return min(0.95, max(_TYPO_ABS_FLOOR_RATIO, floor_from_font + density_adj))


# ═══════════════════════════════════════════════════════════════════════════════
#  DYNAMIC PAGE PARAMETER DERIVATION
# ═══════════════════════════════════════════════════════════════════════════════

def _derive_page_params(geo: PageGeometry, sec: "Section",
                        page_object=None) -> PageParams:
    """Derive all compression parameters from actual page content."""
    resolved_pt   = 1.0 / TWIPS_PER_PT

    states        = sec.live_states()
    all_font_pts  = sorted([ps.font_pt for ps in states if ps.font_pt > 0])
    if not all_font_pts:
        all_font_pts = [10.0]

    n              = len(all_font_pts)
    median_font_pt = all_font_pts[n // 2]
    q1_font_pt     = all_font_pts[n // 4]
    q3_font_pt     = all_font_pts[min(n - 1, (3 * n) // 4)]

    if abs(q3_font_pt - q1_font_pt) < 0.5:
        q1_font_pt = median_font_pt * 0.80
        q3_font_pt = median_font_pt * 1.20

    floor_ratio = _derive_floor_ratio_dynamic(
        page_object, median_font_pt, len(states), sec.available_pt
    )

    overflow_pt = sec.overflow_pt
    avail       = sec.available_pt
    if avail > 0 and overflow_pt > 0:
        ovf_frac = overflow_pt / avail
        if ovf_frac <= 0.02:
            safety_scale = 0.05
        elif ovf_frac <= 0.10:
            t = (ovf_frac - 0.02) / 0.08
            safety_scale = 0.05 + t * 0.25
        elif ovf_frac <= 0.25:
            t = (ovf_frac - 0.10) / 0.15
            safety_scale = 0.30 + t * 0.25
        else:
            safety_scale = 0.55
    else:
        safety_scale = 0.10

    line_vals = [ps.effective_line for ps in states if ps.effective_line > 0]
    median_lv = sorted(line_vals)[len(line_vals) // 2] if line_vals else WORD_SINGLE_LINE
    expand_safety_pt = (median_lv / WORD_SINGLE_LINE) * median_font_pt

    return PageParams(
        buffer              = geo.buffer,
        floor_ratio         = floor_ratio,
        tiny_threshold_pt   = max(1.0, q1_font_pt),
        large_threshold_pt  = max(q1_font_pt + 1.0, q3_font_pt),
        expand_safety_pt    = expand_safety_pt,
        safety_scale_factor = safety_scale,
        resolved_pt         = resolved_pt,
        median_font_pt      = median_font_pt,
    )


