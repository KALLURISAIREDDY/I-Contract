@dataclass
class Section:
    index:         int
    body_elems:    List[object]           = field(default_factory=list)
    sect_pr:       Optional[object]       = None
    page_h_pt:     float                  = 0.0
    top_margin_pt: float                  = 0.0
    bot_margin_pt: float                  = 0.0
    available_pt:  float                  = 0.0
    geo:           Optional[PageGeometry] = None
    params:        Optional[PageParams]   = None

    @property
    def effective_pdf_h(self) -> float:
        return self.geo.effective_h if self.geo else 0.0

    @property
    def resolved_pt(self) -> float:
        return self.params.resolved_pt if self.params else (1.0 / TWIPS_PER_PT)

    @property
    def overflow_pt(self) -> float:
        return max(0.0, self.effective_pdf_h - self.available_pt)

    @property
    def is_overflow(self) -> bool:
        return self.overflow_pt > MIN_OVERFLOW_TRIGGER_PT

    def iter_paragraphs(self):
        for elem in self.body_elems:
            tag = _ltag(elem)
            if tag == "p":
                yield elem, False
            elif tag == "tbl":
                for p in elem.findall(".//" + qn("w:p")):
                    yield p, True

    def live_states(self) -> List[ParaState]:
        return [
            _read_para(p, i, tbl, self.params)
            for i, (p, tbl) in enumerate(self.iter_paragraphs(), start=1)
        ]

    def total_para_spacing_pt(self) -> float:
        return sum(s.para_spacing_pt for s in self.live_states())

    def tier1_capacity_pt(self) -> float:
        return self.total_para_spacing_pt()

    def tier2_capacity_pt(self) -> float:
        return sum(
            (s.above_single_headroom / WORD_SINGLE_LINE) * s.font_pt
            for s in self.live_states()
        )

    def tier3_capacity_pt(self) -> float:
        return sum(
            (s.line_headroom / WORD_SINGLE_LINE) * s.font_pt
            for s in self.live_states()
        )

    def snapshot_all(self) -> Dict[int, ParaSnapshot]:
        snaps: Dict[int, ParaSnapshot] = {}
        for i, (p, tbl) in enumerate(self.iter_paragraphs(), start=1):
            ps = _read_para(p, i, tbl, self.params)
            snaps[i] = ParaSnapshot(
                idx=i, before_tw=ps.before_tw,
                after_tw=ps.after_tw, line_val=ps.line_val
            )
        return snaps

    def current_content_height_pt(self) -> float:
        return sum(ps.line_height_pt + ps.para_spacing_pt
                   for ps in self.live_states())

    def available_width_pt(self) -> float:
        if self.sect_pr is None:
            return 0.0
        pg_sz  = self.sect_pr.find(qn("w:pgSz"))
        pg_mar = self.sect_pr.find(qn("w:pgMar"))
        if pg_sz is None:
            return 0.0
        w_pt = _attr_dxa_to_pt(pg_sz.get(qn("w:w")))
        lm   = _attr_dxa_to_pt(pg_mar.get(qn("w:left")))  if pg_mar is not None else 0.0
        rm   = _attr_dxa_to_pt(pg_mar.get(qn("w:right"))) if pg_mar is not None else 0.0
        col_w = w_pt - lm - rm
        return col_w if col_w > 0 else w_pt * 0.80


