def _get_all_runs(p_elem) -> list:
    return p_elem.findall(".//" + qn("w:r"))


def _get_run_font_hp(r_elem) -> Optional[int]:
    rPr = r_elem.find(qn("w:rPr"))
    if rPr is None:
        return None
    sz = rPr.find(qn("w:sz"))
    if sz is None:
        return None
    v = sz.get(qn("w:val"))
    return int(v) if v else None


def _set_run_font_size(r_elem, new_hp: int) -> None:
    rPr = r_elem.find(qn("w:rPr"))
    if rPr is None:
        rPr = OxmlElement("w:rPr")
        r_elem.insert(0, rPr)
    for local in ("w:sz", "w:szCs"):
        el = rPr.find(qn(local))
        if el is None:
            el = OxmlElement(local)
            rPr.append(el)
        el.set(qn("w:val"), str(max(1, new_hp)))


def _measure_para_text_width_pt(p_elem, default_font_hp: int = 20) -> float:
    runs = _get_all_runs(p_elem)
    if not runs:
        text    = "".join(t.text or "" for t in p_elem.findall(".//" + qn("w:t")))
        font_pt = default_font_hp / HALF_PTS_PER_PT
        return len(text) * font_pt * _AVG_CHAR_WIDTH_FRAC
    total = 0.0
    for r in runs:
        hp      = _get_run_font_hp(r) or default_font_hp
        font_pt = hp / HALF_PTS_PER_PT
        text    = "".join(t.text or "" for t in r.findall(qn("w:t")))
        total  += len(text) * font_pt * _AVG_CHAR_WIDTH_FRAC
    return total


def _is_single_line_para(p_elem) -> bool:
    text = "".join(t.text or "" for t in p_elem.findall(".//" + qn("w:t"))).strip()
    if not text:
        return False
    return not bool(p_elem.findall(".//" + qn("w:br")))


def fix_inline_line_overflow(
    sections:  List[Section],
    pdf_lines: Dict[int, List[PdfLine]],
    log:       List[Action],
) -> int:
    _hdr("STEP A: INLINE LINE-LEVEL OVERFLOW FIX")
    total_fixed = 0
    for sec in sections:
        col_w = sec.available_width_pt()
        if col_w <= 0:
            continue
        page_pdf_lines = pdf_lines.get(sec.index, [])
        if not page_pdf_lines:
            continue
        fixed_on_page = 0
        for para_i, (p_elem, in_table) in enumerate(sec.iter_paragraphs(), start=1):
            if not _is_single_line_para(p_elem):
                continue
            para_text = "".join(t.text or "" for t in p_elem.findall(".//" + qn("w:t"))).strip()
            if len(para_text) < 3:
                continue
            para_font_hp = _median_font_hp(p_elem)
            est_width    = _measure_para_text_width_pt(p_elem, para_font_hp)
            if est_width <= col_w:
                continue
            best_match, best_score = None, 0.0
            for pl in page_pdf_lines:
                score = _text_similarity(para_text, pl.text)
                if score > best_score:
                    best_score = score
                    best_match = pl
            if best_score < _TEXT_MATCH_THRESHOLD or best_match is None:
                if est_width <= col_w * 1.10:
                    continue
                target_w = col_w
            else:
                target_w = min(col_w, best_match.x1 - best_match.x0)
                if target_w <= 0:
                    target_w = col_w
            scale = max(_MIN_INLINE_SCALE, min(1.0, target_w / est_width))
            if scale >= 1.0:
                continue
            runs = _get_all_runs(p_elem)
            if not runs:
                continue
            changed = False
            for r in runs:
                old_hp = _get_run_font_hp(r) or para_font_hp
                new_hp = max(int(old_hp * _MIN_INLINE_SCALE), int(round(old_hp * scale)))
                if new_hp < old_hp:
                    _set_run_font_size(r, new_hp)
                    log.append(Action(sec.index, para_i, para_text[:60],
                                      "A_inline_fix", "w:sz",
                                      old_hp / HALF_PTS_PER_PT, new_hp / HALF_PTS_PER_PT,
                                      (old_hp - new_hp) / HALF_PTS_PER_PT))
                    changed = True
            if changed:
                fixed_on_page += 1
        if fixed_on_page:
            print(f"  Page {sec.index}: {fixed_on_page} lines corrected "
                  f"(col_w={col_w:.1f}pt)")
        total_fixed += fixed_on_page
    print(f"\n  Total lines fixed: {total_fixed}")
    return total_fixed


# ═══════════════════════════════════════════════════════════════════════════════
#  XML HELPERS
# ═══════════════════════════════════════════════════════════════════════════════

def _ltag(elem) -> str:
    t = elem.tag
    return t.split("}")[-1] if "}" in t else t


def _attr_dxa_to_pt(val: Optional[str], default: float = 0.0) -> float:
    if not val:
        return default
    try:
        return int(val) / TWIPS_PER_PT
    except (TypeError, ValueError):
        return default


def _median_font_hp(p_elem) -> int:
    vals = sorted([int(sz.get(qn("w:val")))
                   for sz in p_elem.findall(".//" + qn("w:sz"))
                   if sz.get(qn("w:val")) and sz.get(qn("w:val")).isdigit()])
    return vals[len(vals) // 2] if vals else 20


def _get_text(p_elem, n: int = 80) -> str:
    parts = [t.text for t in p_elem.findall(".//" + qn("w:t")) if t.text]
    s = "".join(parts).strip()
    return (s[:n] + "…") if len(s) > n else s


def _read_para(p_elem, idx: int = 0, in_table: bool = False,
               params: Optional[PageParams] = None) -> ParaState:
    ps = ParaState(
        p_elem=p_elem, idx=idx,
        text=_get_text(p_elem), in_table=in_table,
        font_hp=_median_font_hp(p_elem), params=params,
    )
    pPr = p_elem.find(qn("w:pPr"))
    if pPr is None:
        return ps
    sp = pPr.find(qn("w:spacing"))
    if sp is None:
        return ps
    b = sp.get(qn("w:before"))
    a = sp.get(qn("w:after"))
    l = sp.get(qn("w:line"))
    r = sp.get(qn("w:lineRule"))
    ps.before_tw = int(b) if b else 0
    ps.after_tw  = int(a) if a else 0
    ps.line_val  = int(l) if l else 0
    ps.line_rule = r or ""
    return ps


def _write_spacing(p_elem, before_tw, after_tw, line_val=None, floor_val=0):
    pPr = p_elem.find(qn("w:pPr"))
    if pPr is None:
        pPr = OxmlElement("w:pPr")
        p_elem.insert(0, pPr)
    sp = pPr.find(qn("w:spacing"))
    if sp is None:
        sp = OxmlElement("w:spacing")
        pPr.append(sp)
    sp.set(qn("w:before"), str(max(0, before_tw)))
    sp.set(qn("w:after"),  str(max(0, after_tw)))
    if line_val is not None:
        sp.set(qn("w:line"),     str(max(floor_val, line_val)))
        sp.set(qn("w:lineRule"), "auto")


def _get_style_line_val(p_elem, doc: Optional[Document]) -> int:
    pPr    = p_elem.find(qn("w:pPr"))
    if pPr is None:
        return WORD_SINGLE_LINE
    pStyle = pPr.find(qn("w:pStyle"))
    if pStyle is None or doc is None:
        return WORD_SINGLE_LINE
    style_id    = pStyle.get(qn("w:val"), "")
    styles_root = doc.element.find(".//" + qn("w:styles"))
    if not style_id or styles_root is None:
        return WORD_SINGLE_LINE
    for style in styles_root.findall(qn("w:style")):
        if style.get(qn("w:styleId")) == style_id:
            pPr_s = style.find(qn("w:pPr"))
            if pPr_s is not None:
                sp_s = pPr_s.find(qn("w:spacing"))
                if sp_s is not None:
                    lv = sp_s.get(qn("w:line"))
                    if lv:
                        return int(lv)
    return WORD_SINGLE_LINE


