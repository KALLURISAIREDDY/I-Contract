def _norm(text: str) -> str:
    return re.sub(r"\s+", " ", text.strip().lower())


def _text_similarity(a: str, b: str) -> float:
    if not a or not b:
        return 0.0
    ta = set(_norm(a).split())
    tb = set(_norm(b).split())
    if not ta or not tb:
        return 0.0
    return len(ta & tb) / max(len(ta), len(tb))


def _group_words_into_lines(words: list, line_tol_pt: float = 3.0) -> List[dict]:
    if not words:
        return []
    words = sorted(words, key=lambda w: (round(w["top"] / line_tol_pt), w["x0"]))
    lines, cur_line = [], [words[0]]
    for w in words[1:]:
        pm = (cur_line[-1]["top"] + cur_line[-1]["bottom"]) / 2.0
        tm = (w["top"] + w["bottom"]) / 2.0
        if abs(tm - pm) <= line_tol_pt:
            cur_line.append(w)
        else:
            lines.append(cur_line)
            cur_line = [w]
    lines.append(cur_line)
    result = []
    for grp in lines:
        text  = " ".join(w["text"] for w in grp)
        x0    = min(w["x0"]     for w in grp)
        x1    = max(w["x1"]     for w in grp)
        y_top = min(w["top"]    for w in grp)
        y_bot = max(w["bottom"] for w in grp)
        result.append({"text": text, "x0": x0, "x1": x1,
                        "y_top": y_top, "y_bot": y_bot, "width": x1 - x0})
    return result


def _dominant_font_size_on_line(page, y_top, y_bot, x0, x1) -> float:
    tol   = 2.0
    sizes = [float(ch["size"])
             for ch in (page.chars or [])
             if (ch["top"]    >= y_top - tol and ch["bottom"] <= y_bot + tol
                 and ch["x0"] >= x0   - tol and ch["x1"]    <= x1   + tol
                 and ch.get("size") and ch["size"] > 0)]
    if not sizes:
        return 10.0
    sizes.sort()
    return sizes[len(sizes) // 2]


def extract_pdf_lines_per_page(pdf_path: str) -> Dict[int, List[PdfLine]]:
    _hdr("STEP 1b: PDF LINE EXTRACTION")
    result: Dict[int, List[PdfLine]] = {}
    with pdfplumber.open(pdf_path) as pdf:
        for i, page in enumerate(pdf.pages, 1):
            words     = page.extract_words() or []
            raw_lines = _group_words_into_lines(words)
            pdf_lines = []
            for rl in raw_lines:
                fs = _dominant_font_size_on_line(
                    page, rl["y_top"], rl["y_bot"], rl["x0"], rl["x1"])
                pdf_lines.append(PdfLine(
                    page_num=i, text=rl["text"],
                    x0=rl["x0"], x1=rl["x1"],
                    y_top=rl["y_top"], y_bot=rl["y_bot"],
                    font_size=fs, line_w=rl["width"],
                ))
            result[i] = pdf_lines
            print(f"  Page {i}: {len(pdf_lines)} lines", end="\r")
    total = sum(len(v) for v in result.values())
    print(f"\n  Total lines extracted: {total}")
    return result


